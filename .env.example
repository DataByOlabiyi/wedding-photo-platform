# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL (used for email confirmation links)
NEXT_PUBLIC_URL=http://localhost:3000

# Rate limiting (Upstash Redis) — required in production
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# Paystack billing — set NEXT_PUBLIC_BETA_FREE_PRO=false and add keys to activate payments
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret
PAYSTACK_PRO_PLAN_CODE=PLN_...
NEXT_PUBLIC_BETA_FREE_PRO=true

# Email notifications (Resend) — optional
RESEND_API_KEY=re_...

# PIN cookie signing — generate with: openssl rand -hex 32
PIN_COOKIE_SECRET=your-32-byte-hex-secret-here

# Error tracking (Sentry) — optional but recommended in production
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=your-org
SENTRY_PROJECT=wedding-photo-platform

# Sentry environment tag — set to "production" in Vercel prod, "preview" for previews
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
