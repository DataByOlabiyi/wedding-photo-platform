# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin Security
ADMIN_PASSWORD=bmwedding
JWT_SECRET=your-jwt-secret-key-change-this-in-production

# Email Notifications (Optional - Resend)
RESEND_API_KEY=your-resend-api-key
COUPLE_EMAIL=couple@example.com

# Rate Limiting (Optional - Upstash)
UPSTASH_REDIS_REST_URL=your-upstash-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Gallery Token (Optional) - for read-only shareable link
NEXT_PUBLIC_GALLERY_TOKEN=your-gallery-access-token
NEXT_PUBLIC_URL=https://your-domain.com
